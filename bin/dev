#!/usr/bin/env bash
# Dev workflow shortcut. Spins up Vite (HMR) + Django (--reload) + Postgres,
# tails logs minus the routeTree.gen.ts noise. Source code is bind-mounted
# from the host (./backend, ./frontend, ./public, ./design-system) so changes
# reflect immediately without rebuilds.
#
#   bin/dev          start + watch + tail
#   bin/dev down     stop everything
#   bin/dev restart  restart all services
#   bin/dev logs     just tail
set -e

PROFILE="--profile dev"

case "${1:-up}" in
  up)
    docker compose $PROFILE up -d
    echo "→ tailing logs (Ctrl+C stops the tail; services keep running)"
    docker compose $PROFILE logs -f 2>&1 \
      | grep --line-buffered -v "routeTree.gen.ts was modified by another process"
    ;;
  down)    docker compose $PROFILE down ;;
  restart) docker compose $PROFILE restart ;;
  logs)
    docker compose $PROFILE logs -f 2>&1 \
      | grep --line-buffered -v "routeTree.gen.ts was modified by another process"
    ;;
  *)
    echo "Usage: $0 [up|down|restart|logs]" >&2
    exit 1
    ;;
esac
