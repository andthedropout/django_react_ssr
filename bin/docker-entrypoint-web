#!/usr/bin/env bash
# Web container entrypoint: run migrations (with retry for serverless DB wake-up),
# create the default superuser on first deploy, then exec the actual command.
set -e

cd /app/backend

# Run migrations only if needed. Retry with exponential backoff (1s, 2s, 4s, 8s)
# so cold-starting Postgres on Railway/Fly doesn't fail the boot.
if python manage.py migrate --check >/dev/null 2>&1; then
  echo "✅ migrations up to date"
else
  echo "→ applying migrations..."
  attempt=0
  until python manage.py migrate --noinput; do
    attempt=$((attempt + 1))
    if [ "$attempt" -ge 5 ]; then
      echo "✗ migration failed after 5 attempts" >&2
      exit 1
    fi
    sleep $((2 ** (attempt - 1)))
  done
fi

# Create the default superuser exactly once per deployment.
if [ -n "$RAILWAY_DEPLOYMENT_ID" ] && [ ! -f /tmp/.superuser_created ]; then
  if [[ "$RAILWAY_ENVIRONMENT_NAME" =~ ^pr- ]]; then
    echo "→ skipping superuser (PR preview)"
  else
    python manage.py create_default_superuser && touch /tmp/.superuser_created || true
  fi
fi

exec "$@"
