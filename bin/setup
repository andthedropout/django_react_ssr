#!/usr/bin/env bash
# First-time setup for a fresh clone of this template:
#   1. Copy .env.example → .env
#   2. Optionally rename the project (one find/replace, then you're done)
#   3. Auto-pick host ports that aren't conflicting with anything else
#   4. Build the prod stack and run migrations
#
# Re-runnable: skips steps that are already done.
set -e

cd "$(dirname "$0")/.."

echo "🚀 Django + React Starter — Setup"
echo "──────────────────────────────────"
echo ""

if ! docker info >/dev/null 2>&1; then
  echo "✗ Docker is not running. Start Docker and re-run." >&2
  exit 1
fi

# Step 1 — .env from example.
if [ ! -f .env ]; then
  cp .env.example .env
  echo "✓ created .env from .env.example"
else
  echo "• .env already exists (skipping copy)"
fi

# Step 2 — optional project rename.
current_name="$(grep -E '^export COMPOSE_PROJECT_NAME=' .env | head -1 | cut -d= -f2 | tr -d '"' | tr -d "'")"
echo ""
echo "Current project name: ${current_name:-(unset)}"
read -p "Rename this project? [y/N]: " -r yn
if [[ "${yn:-n}" =~ ^[Yy]$ ]]; then
  read -p "  app name (lowercase, e.g. myapp): " APP_NAME
  read -p "  module name (PascalCase, e.g. MyApp): " MODULE_NAME
  if [ -n "$APP_NAME" ] && [ -n "$MODULE_NAME" ]; then
    ./bin/rename-project "$APP_NAME" "$MODULE_NAME"
  fi
fi

# Step 3 — pick conflict-free host ports.
echo ""
./bin/pick-ports

# Step 4 — build & start the prod stack (web + ssr + nginx + postgres).
echo ""
echo "→ building & starting Docker services..."
docker compose --profile prod up --build -d

# Step 5 — wait for the web container's healthcheck (gunicorn boots after migrations).
echo ""
echo "→ waiting for web container to become ready..."
for i in $(seq 1 60); do
  if docker compose exec -T web curl -sf http://localhost:8000/up >/dev/null 2>&1; then
    echo "✓ web is responding"
    break
  fi
  sleep 1
done

# Step 6 — surface the actual URLs (using the ports we just picked).
WEB_PORT="$(grep -E '^WEB_PORT=' .env | head -1 | cut -d= -f2)"
WEB_PORT="${WEB_PORT:-8002}"
ADMIN_USER="$(grep -E '^DJANGO_SUPERUSER_USERNAME=' .env | head -1 | cut -d= -f2)"
ADMIN_PASS="$(grep -E '^DJANGO_SUPERUSER_PASSWORD=' .env | head -1 | cut -d= -f2)"

cat <<EOF

✅ Setup complete.

   App:    http://localhost:${WEB_PORT}
   Admin:  http://localhost:${WEB_PORT}/admin    (${ADMIN_USER:-admin} / ${ADMIN_PASS:-changeme})
   Health: http://localhost:${WEB_PORT}/up

Useful commands:
   docker compose --profile prod up -d        Start the prod stack
   docker compose --profile dev  up           Start dev (Vite HMR + Django reload)
   docker compose logs -f                     Tail all logs
   docker compose down                        Stop everything
   bin/pick-ports --force                     Reassign all host ports

EOF
