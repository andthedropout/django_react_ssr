# =============================================================================
# Starter env — copy to .env, then run `bin/pick-ports` to claim free host ports.
# Most defaults work out of the box. Things you ALWAYS want to change before
# shipping to production are flagged with `# CHANGE`.
# =============================================================================

# Single source of truth for the project name.
# Drives Docker volumes/networks, Celery app name, session/CSRF cookie names.
# Rename here and `bin/rename-project` will propagate everywhere else.
export COMPOSE_PROJECT_NAME=django_react_ssr
export VITE_PROJECT_NAME=django_react_ssr

# Host ports. `bin/pick-ports` rewrites these to non-conflicting values
# automatically on first setup so multiple clones can run side-by-side.
WEB_PORT=8002        # nginx (prod profile) — the only port you visit in a browser
DJANGO_PORT=8000     # gunicorn directly (dev profile, when running without nginx)
VITE_PORT=5175       # Vite dev server with HMR (dev profile)

# Django basics — CHANGE SECRET_KEY before going to production.
export SECRET_KEY=insecure_key_for_dev
export DEBUG=true
export ALLOWED_HOSTS="*"   # CHANGE to your real domain(s) in prod
export CSRF_TRUSTED_ORIGINS=http://localhost:8002,http://127.0.0.1:8002

# Database (matches what `postgres` service expects).
export POSTGRES_USER=django_react_ssr
export POSTGRES_PASSWORD=your_postgres_password_here   # CHANGE
export POSTGRES_DB=django_react_ssr

# Redis URL. Comment out to fall back to the database cache (Celery disabled).
export REDIS_URL=redis://redis:6379/0

# Default superuser created on first prod deploy. CHANGE before shipping.
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=changeme

# Frontend theme — pick any *.json from design-system/themes/
# (vercel, cyberpunk, tangerine, nature, mono, catppuccin, doom-64, ...)
VITE_FRONTEND_THEME=vercel

# Site URL (for absolute links + OpenGraph).
SITE_URL=http://localhost:8002

# --- Less commonly touched ---
export DOCKER_BUILDKIT=1
export PYTHONDONTWRITEBYTECODE=true
export NODE_ENV=development
export DOCKER_RESTART_POLICY=no       # `unless-stopped` in real deployments
#export WEB_CONCURRENCY=               # gunicorn workers (defaults to CPU*2)
#export WEB_TIMEOUT=120
#export CELERY_LOG_LEVEL=info
#export CELERY_WORKER_CONCURRENCY=2
#export UID=1000                       # only matters on native Linux
#export GID=1000
